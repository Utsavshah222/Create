<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="22sp"
            android:textStyle="bold"
            android:paddingBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="All settings stay on this device. Nothing is stored on a server."
            android:textSize="12sp"
            android:paddingBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Step 1 — Choose SIM"
            android:textStyle="bold"
            android:textSize="16sp"
            android:paddingTop="8dp" />

        <TextView
            android:id="@+id/simHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:paddingBottom="4dp" />

        <RadioGroup
            android:id="@+id/simGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Step 2 — Permissions"
            android:textStyle="bold"
            android:textSize="16sp"
            android:paddingTop="20dp" />

        <Button
            android:id="@+id/grantBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Grant SMS + Phone permissions" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Step 3 — WhatsApp groups (one id per line)"
            android:textStyle="bold"
            android:textSize="16sp"
            android:paddingTop="20dp" />

        <EditText
            android:id="@+id/groupsInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textMultiLine"
            android:minLines="2"
            android:gravity="top"
            android:hint="120363...@g.us" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Forward only messages containing (comma separated)"
            android:textStyle="bold"
            android:textSize="14sp"
            android:paddingTop="16dp" />

        <EditText
            android:id="@+id/keywordsInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:hint="debited,credited" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Gateway endpoint"
            android:textStyle="bold"
            android:textSize="14sp"
            android:paddingTop="16dp" />

        <EditText
            android:id="@+id/urlInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textUri" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Authorization header"
            android:textStyle="bold"
            android:textSize="14sp"
            android:paddingTop="12dp" />

        <EditText
            android:id="@+id/authInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="x-device-id header"
            android:textStyle="bold"
            android:textSize="14sp"
            android:paddingTop="12dp" />

        <EditText
            android:id="@+id/deviceInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text" />

        <Switch
            android:id="@+id/enabledSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Enabled (forward in background)"
            android:paddingTop="24dp" />

        <Button
            android:id="@+id/saveBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save"
            android:layout_marginTop="8dp" />

        <TextView
            android:id="@+id/status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textSize="13sp"
            android:paddingTop="20dp" />

    </LinearLayout>
</ScrollView>
